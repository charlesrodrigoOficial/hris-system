generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EmployeeDocumentCategory {
  EDUCATION
  EMPLOYMENT
  WORK_ELIGIBILITY
  PERSONAL
}

enum CompanyDocumentCategory {
  EMPLOYMENT_LETTER
  CONTRACT
  HANDBOOK
  HR_POLICY
  GUIDE
}

enum SupportRequestType {
  RECOMMENDATION_LETTER
  EMPLOYMENT_VERIFICATION
  PROOF_OF_INCOME
  CONTRACT_COPY
  OPERATIONAL_REQUEST
  OTHER
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum Country {
  UNITED_KINGDOM
  PAKISTAN
  MALAYSIA
  INDIA
  SRI_LANKA
  BANGLADESH
  USA
  CANADA
  AUSTRALIA
  INDONESIA
  THAILAND
}

enum FeedPostType {
  SHOUTOUT
  KUDOS
  POLL
  BIRTHDAY
}

enum FeedReactionType {
  LIKE
  DISLIKE
  HEART
  HAHA
  SMILE
}

enum RequestType {
  LEAVE
  CLAIM
  SUPPORT
}

enum RequestStatus {
  PENDING
  PROCESSING
  APPROVED
  REJECTED
}

enum LeaveRequestType {
  PAID_VACATION_LEAVE
  SICK_LEAVE
  URGENT_LEAVE
  MATERNITY_LEAVE
  PATERNITY_LEAVE
  BEREAVEMENT_LEAVE
  UNPAID_LEAVE
  MENTAL_WELLNESS_DAY
}

enum ClaimPurpose {
  TEAM_MEAL_OR_COFFEE
  EMPLOYEE_ENGAGEMENT_WINNER
  BEST_EMPLOYEE_RECOGNITION
  BIRTHDAY_VOUCHER
  TRANSPORT
  OFFICE_SUPPLIES
  TRAINING_CERTIFICATION_COURSES
  OTHER
}

enum RequestAttachmentType {
  GENERAL
  MANAGER_APPROVAL
  CLAIM_RECEIPT
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACTOR
  INTERN
}

enum ReviewStatus {
  WAITING_FOR_REVIEW
  PROCESSING
  CONFIRMED
}

enum UserRole {
  SUPER_ADMIN
  HR_MANAGER
  PAYROLL_MANAGER
  EMPLOYEE
}

enum AttendanceStatus {
  PRESENT
  HALF_DAY
  ABSENT
  LEAVE
  HOLIDAY
  WEEKOFF
  PUBLIC_HOLIDAY
}

enum CalendarItemType {
  EVENT
  HOLIDAY
  MEETING
  PAYROLL
  SHIFT
  ANNOUNCEMENT
}

enum CalendarVisibility {
  COMPANY
  DEPARTMENT
  PERSONAL
}

enum PayCycleStatus {
  OPEN
  CLOSED
}

enum PayrollRunStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  COMPLETED
  CALCULATED
}

enum PayslipStatus {
  DRAFT
  PUBLISHED
  VOIDED
}

enum PayrollPolicyStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum PayrollRuleKind {
  EARNING
  TAX
  DEDUCTION
}

enum PayrollRuleValueType {
  PERCENT
  FIXED
}

model EmployeeDocument {
  id     String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title       String
  category    EmployeeDocumentCategory
  fileName    String
  fileUrl     String
  fileType    String?
  fileSize    Int?
  sourceLabel String? // "Onboarding", "HR Upload", "Employee Upload"
  uploadedBy  String? // optional display label
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  @@index([userId])
  @@index([category])
}

model CalendarItem {
  id          String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String
  description String?
  type        CalendarItemType
  visibility  CalendarVisibility @default(COMPANY)

  startDate DateTime
  endDate   DateTime
  allDay    Boolean  @default(true)

  color   String?
  country Country?

  // personal calendar event
  userId String? @db.Uuid
  user   User?   @relation("CalendarUser", fields: [userId], references: [id], onDelete: SetNull)

  // department-wide calendar event
  departmentId String?     @db.Uuid
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  // who created it
  createdById String? @db.Uuid
  createdBy   User?   @relation("CalendarCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([visibility])
  @@index([startDate])
  @@index([endDate])
  @@index([country])
  @@index([userId])
  @@index([departmentId])
  @@index([createdById])
}

model CompanyDocument {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  title       String
  category    CompanyDocumentCategory
  fileName    String
  fileUrl     String
  fileType    String?
  fileSize    Int?
  sourceLabel String?
  uploadedBy  String?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  @@index([category])
}

model User {
  id                   String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                 String?         @default("No NAME")
  fullName             String?
  firstName            String?
  lastName             String?
  email                String          @unique(map: "user_email_idx")
  emailVerified        DateTime?       @db.Timestamp(6)
  image                String?
  password             String? //for Hash password we can use bcrypt
  role                 UserRole        @default(EMPLOYEE)
  mfaEnabled           Boolean         @default(false)
  permissions          String[]        @default([])
  dateOfBirth          DateTime?       @db.Date
  address              String?         @db.Text
  postCode             String?
  nationalId           String?
  phoneNo              String?
  gender               Gender?
  accountName          String?
  accountNumber        String?
  swiftCode            String?
  iban                 String?
  sortCode             String?
  workEligibility      String?
  hireDate             DateTime?
  currency             String?         @default("GBP")
  salary               Decimal?        @db.Decimal(12, 2)
  employmentType       EmploymentType?
  contractEndDate      DateTime?       @db.Date
  isActive             Boolean         @default(false)
  originalCompany      String?
  officeLocation       String?
  onboardingLocation   String?
  onboardingTravel     String?
  orgLevel             String?
  accessPerssiions     String?         @default("user")
  remoteWork           Boolean?
  departmentId         String?         @db.Uuid
  branchId             String?         @db.Uuid
  position             String?
  managerId            String?         @db.Uuid
  secondLevelManagerId String?         @db.Uuid
  shiftId              String?         @db.Uuid

  about                  String?  @db.Text
  linkedIn               String?
  hobbies                String?  @db.Text
  superpowers            String?  @db.Text
  mostFascinatingTrip    String?  @db.Text
  dreamTravelDestination String?
  country                Country?

  department         Department?         @relation("DepartmentEmployees", fields: [departmentId], references: [id], onDelete: Restrict)
  branch             Branch?             @relation("BranchEmployees", fields: [branchId], references: [id], onDelete: SetNull)
  managesBranch      Branch?             @relation("BranchManager")
  managedDepartments Department[]        @relation("DepartmentManager")
  managedRequests    Request[]           @relation("RequestManager")
  manager            User?               @relation("UserManager", fields: [managerId], references: [id], onDelete: SetNull)
  directReports      User[]              @relation("UserManager")
  secondLevelManager User?               @relation("UserSecondLevelManager", fields: [secondLevelManagerId], references: [id], onDelete: SetNull)
  secondLevelReports User[]              @relation("UserSecondLevelManager")
  shift              Shift?              @relation(fields: [shiftId], references: [id])
  performanceReviews PerformanceReview[]

  sessions                Session[]
  account                 Account[]
  attendances             Attendance[]
  requests                Request[]
  requestActivity         RequestActivity[]
  notifications           Notification[]
  birthdayWishesReceived  BirthdayWish[]       @relation("BirthdayWishRecipient")
  birthdayWishesSent      BirthdayWish[]       @relation("BirthdayWishSender")
  feedPost                FeedPost[]           @relation("FeedPostAuthor")
  birthdayFeedPosts       FeedPost[]           @relation("FeedPostBirthdayUser")
  feedReaction            FeedReaction[]
  feedComments            FeedComment[]
  employeeDocuments       EmployeeDocument[]
  payCyclesCreated        PayCycle[]           @relation("PayCycleCreatedBy")
  payrollRunsCreated      PayrollRun[]         @relation("PayrollRunCreatedBy")
  payrollRunEmployees     PayrollRunEmployee[] @relation("PayrollRunEmployeeUser")
  payrollRunsReviewed     PayrollRunEmployee[] @relation("PayrollRunEmployeeReviewedBy")
  payslips                Payslip[]            @relation("PayslipUser")
  payrollAuditTriggered   PayrollAuditLog[]    @relation("PayrollAuditActor")
  payrollAuditOnUser      PayrollAuditLog[]    @relation("PayrollAuditTargetUser")
  payrollPoliciesCreated  PayrollPolicy[]      @relation("PayrollPolicyCreatedBy")
  payrollPoliciesApproved PayrollPolicy[]      @relation("PayrollPolicyApprovedBy")

  calendarItems        CalendarItem[] @relation("CalendarUser")
  calendarItemsCreated CalendarItem[] @relation("CalendarCreatedBy")

  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @updatedAt

  @@index([departmentId])
  @@index([branchId])
  @@index([managerId])
  @@index([secondLevelManagerId])
  @@index([dateOfBirth])
  @@index([country])
  @@index([isActive])
}

model Account {
  userId            String  @db.Uuid
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId]) //Combine both and creates a primary key
}

model Session {
  sessionToken String   @id
  userId       String   @db.Uuid
  expires      DateTime @db.Timestamp(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model PerformanceReview {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  employeeId String @db.Uuid
  employee   User   @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  // store the month (recommended: first day of the month)
  month  DateTime     @db.Date
  status ReviewStatus @default(WAITING_FOR_REVIEW)

  // optional fields for later
  score Decimal? @db.Decimal(5, 2)
  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeeId, month], name: "unique_review_per_employee_month")
  @@index([month])
  @@index([employeeId])
}

model Attendance {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  date DateTime @db.Date

  checkIn      DateTime?
  checkOut     DateTime?
  workingHours Decimal?  @db.Decimal(6, 2)

  status AttendanceStatus

  workMode WorkMode @default(OFFICE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
  @@index([date])
  @@index([userId])
  @@index([status, date])
}

enum WorkMode {
  OFFICE
  REMOTE
}

model Branch {
  id            String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branchName    String
  branchAddress String
  branchPhone   String
  empCount      Int

  branchEmail String

  employees User[] @relation("BranchEmployees") // Employees assigned to this branch

  branchManagerId String?  @unique @db.Uuid // Branch manager (picked from User)
  branchManager   User?    @relation("BranchManager", fields: [branchManagerId], references: [id], onDelete: SetNull)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([branchName])
}

model Department {
  id             String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  departmentName String @unique
  empCount       Int    @default(0)

  depManagerId String? @db.Uuid
  depManager   User?   @relation("DepartmentManager", fields: [depManagerId], references: [id], onDelete: SetNull)

  employees User[] @relation("DepartmentEmployees")

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  calendarItems CalendarItem[]

  @@index([depManagerId])
}

model Shift {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String  @unique
  startTime   String
  endTime     String
  multiplier  Decimal @default(1.0) @db.Decimal(5, 2)
  description String?

  employees User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Request {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type        RequestType
  title       String
  description String?
  status      RequestStatus @default(PENDING)

  // Optional structured fields
  supportRequestType      SupportRequestType? // support
  supportRequestTypeOther String?
  expectedCompletionDate  DateTime? // support
  supportAdditionalNotes  String?
  leaveType               LeaveRequestType? // leave
  startDate               DateTime? // leave
  endDate                 DateTime? // leave
  claimPurpose            ClaimPurpose? // claim
  claimPurposeOther       String?
  expenseDate             DateTime? // claim
  managerEmployeeId       String?             @db.Uuid
  managerEmployee         User?               @relation("RequestManager", fields: [managerEmployeeId], references: [id], onDelete: SetNull)
  bankName                String?
  accountNumber           String?
  ibanSwift               String?
  amount                  Decimal?            @db.Decimal(10, 2) // claim
  currency                String? // claim e.g. "GBP"

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  attachments Attachment[] // receipts / docs
  activities  RequestActivity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([supportRequestType])
  @@index([leaveType])
  @@index([claimPurpose])
  @@index([managerEmployeeId])
  @@index([userId])
  @@index([type, status])
  @@index([startDate])
  @@index([endDate])
}

model Attachment {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  requestId String  @db.Uuid
  request   Request @relation(fields: [requestId], references: [id], onDelete: Cascade)

  fileName       String
  fileUrl        String
  fileType       String?
  fileSize       Int?
  attachmentType RequestAttachmentType @default(GENERAL)

  createdAt DateTime @default(now())
}

model RequestActivity {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  requestId String  @db.Uuid
  request   Request @relation(fields: [requestId], references: [id], onDelete: Cascade)

  actorId String @db.Uuid
  actor   User   @relation(fields: [actorId], references: [id], onDelete: Cascade)

  fromStatus RequestStatus?
  toStatus   RequestStatus?
  note       String?

  createdAt DateTime @default(now())
}

model Notification {
  id     String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title   String
  message String
  href    String?
  isRead  Boolean @default(false)

  createdAt DateTime @default(now())
}

model BirthdayWish {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  birthdayUserId String @db.Uuid
  birthdayUser   User   @relation("BirthdayWishRecipient", fields: [birthdayUserId], references: [id], onDelete: Cascade)

  wishedById String @db.Uuid
  wishedBy   User   @relation("BirthdayWishSender", fields: [wishedById], references: [id], onDelete: Cascade)

  wishDate  DateTime @db.Date
  createdAt DateTime @default(now())

  @@unique([birthdayUserId, wishedById, wishDate])
  @@index([wishDate])
  @@index([wishedById])
}

model FeedPost {
  id   String       @id @default(uuid()) @db.Uuid
  type FeedPostType @default(SHOUTOUT)

  content  String
  imageUrl String?

  // Birthday post fields
  birthdayUserId String? @db.Uuid
  birthdayUser   User?   @relation("FeedPostBirthdayUser", fields: [birthdayUserId], references: [id], onDelete: SetNull)

  // Poll fields
  pollQuestion String?
  pollOptions  Json?

  authorId String @db.Uuid
  author   User   @relation("FeedPostAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reactions FeedReaction[]
  comments  FeedComment[]

  @@index([authorId])
  @@index([createdAt])
  @@index([type])
  @@index([birthdayUserId])
}

model FeedReaction {
  id     String           @id @default(uuid()) @db.Uuid
  postId String           @db.Uuid
  userId String           @db.Uuid
  type   FeedReactionType @default(LIKE)

  post FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
}

model FeedComment {
  id      String @id @default(uuid()) @db.Uuid
  postId  String @db.Uuid
  userId  String @db.Uuid
  content String

  post FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([postId])
  @@index([userId])
}

model PayCycle {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  periodStart DateTime       @map("period_start") @db.Date
  periodEnd   DateTime       @map("period_end") @db.Date
  payDate     DateTime       @map("pay_date") @db.Date
  status      PayCycleStatus @default(OPEN)
  createdById String?        @map("created_by_id") @db.Uuid
  createdBy   User?          @relation("PayCycleCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  payrollRuns PayrollRun[]
  auditLogs   PayrollAuditLog[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([periodStart, periodEnd])
  @@index([payDate])
  @@index([status])
  @@map("pay_cycles")
}

model PayrollRun {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  payCycleId  String           @map("pay_cycle_id") @db.Uuid
  payCycle    PayCycle         @relation(fields: [payCycleId], references: [id], onDelete: Cascade)
  runNumber   Int              @default(1) @map("run_number")
  status      PayrollRunStatus @default(DRAFT)
  startedAt   DateTime?        @map("started_at")
  reviewedAt  DateTime?        @map("reviewed_at")
  completedAt DateTime?        @map("completed_at")
  syncedAt    DateTime?        @map("synced_at")
  createdById String?          @map("created_by_id") @db.Uuid
  createdBy   User?            @relation("PayrollRunCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  runEmployees PayrollRunEmployee[]
  payslips     Payslip[]
  auditLogs    PayrollAuditLog[]

  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  payrollPolicy   PayrollPolicy? @relation(fields: [payrollPolicyId], references: [id])
  payrollPolicyId String?        @db.Uuid

  @@unique([payCycleId, runNumber])
  @@index([status])
  @@index([payCycleId])
  @@map("payroll_runs")
}

model PayrollRunEmployee {
  id              String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  payrollRunId    String     @map("payroll_run_id") @db.Uuid
  payrollRun      PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  userId          String     @map("employee_id") @db.Uuid
  user            User       @relation("PayrollRunEmployeeUser", fields: [userId], references: [id], onDelete: Cascade)
  baseSalary      Decimal    @default(0) @map("base_salary") @db.Decimal(12, 2)
  grossPay        Decimal    @default(0) @map("gross_pay") @db.Decimal(12, 2)
  taxesTotal      Decimal    @default(0) @map("taxes_total") @db.Decimal(12, 2)
  deductionsTotal Decimal    @default(0) @map("deductions_total") @db.Decimal(12, 2)
  netPay          Decimal    @default(0) @map("net_pay") @db.Decimal(12, 2)
  varianceAmount  Decimal    @default(0) @map("variance_amount") @db.Decimal(12, 2)
  varianceNote    String?    @map("variance_note") @db.Text
  reviewedAt      DateTime?  @map("reviewed_at")
  reviewedById    String?    @map("reviewed_by_id") @db.Uuid
  reviewedBy      User?      @relation("PayrollRunEmployeeReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  payslip Payslip?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([payrollRunId, userId])
  @@index([userId])
  @@index([reviewedById])
  @@map("payroll_run_employees")
}

model Payslip {
  id                   String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  payrollRunId         String              @map("payroll_run_id") @db.Uuid
  payrollRun           PayrollRun          @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  payrollRunEmployeeId String?             @unique @map("payroll_run_employee_id") @db.Uuid
  payrollRunEmployee   PayrollRunEmployee? @relation(fields: [payrollRunEmployeeId], references: [id], onDelete: SetNull)
  userId               String              @map("employee_id") @db.Uuid
  user                 User                @relation("PayslipUser", fields: [userId], references: [id], onDelete: Cascade)
  payDate              DateTime            @map("pay_date") @db.Date
  periodStart          DateTime            @map("period_start") @db.Date
  periodEnd            DateTime            @map("period_end") @db.Date
  currency             String              @default("GBP")
  grossPay             Decimal             @default(0) @map("gross_pay") @db.Decimal(12, 2)
  taxesTotal           Decimal             @default(0) @map("taxes_total") @db.Decimal(12, 2)
  deductionsTotal      Decimal             @default(0) @map("deductions_total") @db.Decimal(12, 2)
  netPay               Decimal             @default(0) @map("net_pay") @db.Decimal(12, 2)
  status               PayslipStatus       @default(DRAFT)
  pdfUrl               String?             @map("pdf_url")
  publishedAt          DateTime?           @map("published_at")

  earnings   PayslipEarning[]
  taxes      PayslipTax[]
  deductions PayslipDeduction[]
  auditLogs  PayrollAuditLog[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([payrollRunId, userId])
  @@index([userId, payDate])
  @@index([status])
  @@map("payslips")
}

model PayslipEarning {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  payslipId String   @map("payslip_id") @db.Uuid
  payslip   Payslip  @relation(fields: [payslipId], references: [id], onDelete: Cascade)
  label     String
  amount    Decimal  @default(0) @db.Decimal(12, 2)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([payslipId])
  @@map("payslip_earnings")
}

model PayslipTax {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  payslipId String   @map("payslip_id") @db.Uuid
  payslip   Payslip  @relation(fields: [payslipId], references: [id], onDelete: Cascade)
  label     String
  amount    Decimal  @default(0) @db.Decimal(12, 2)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([payslipId])
  @@map("payslip_taxes")
}

model PayslipDeduction {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  payslipId String   @map("payslip_id") @db.Uuid
  payslip   Payslip  @relation(fields: [payslipId], references: [id], onDelete: Cascade)
  label     String
  amount    Decimal  @default(0) @db.Decimal(12, 2)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([payslipId])
  @@map("payslip_deductions")
}

model PayrollAuditLog {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorId      String      @map("actor_id") @db.Uuid
  actor        User        @relation("PayrollAuditActor", fields: [actorId], references: [id], onDelete: Cascade)
  userId       String?     @map("employee_id") @db.Uuid
  user         User?       @relation("PayrollAuditTargetUser", fields: [userId], references: [id], onDelete: SetNull)
  payCycleId   String?     @map("pay_cycle_id") @db.Uuid
  payCycle     PayCycle?   @relation(fields: [payCycleId], references: [id], onDelete: SetNull)
  payrollRunId String?     @map("payroll_run_id") @db.Uuid
  payrollRun   PayrollRun? @relation(fields: [payrollRunId], references: [id], onDelete: SetNull)
  payslipId    String?     @map("payslip_id") @db.Uuid
  payslip      Payslip?    @relation(fields: [payslipId], references: [id], onDelete: SetNull)
  action       String
  details      Json?
  createdAt    DateTime    @default(now()) @map("created_at")

  @@index([actorId])
  @@index([userId])
  @@index([payrollRunId])
  @@index([payslipId])
  @@map("audit_log")
}

model PayrollPolicy {
  id            String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String
  version       Int                 @default(1)
  status        PayrollPolicyStatus @default(DRAFT)
  currency      String              @default("GBP")
  effectiveFrom DateTime            @map("effective_from") @db.Date
  effectiveTo   DateTime?           @map("effective_to") @db.Date
  notes         String?             @db.Text

  createdById  String? @map("created_by_id") @db.Uuid
  createdBy    User?   @relation("PayrollPolicyCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  approvedById String? @map("approved_by_id") @db.Uuid
  approvedBy   User?   @relation("PayrollPolicyApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)

  rules       PayrollPolicyRule[]
  payrollRuns PayrollRun[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([name, version])
  @@index([status, effectiveFrom, effectiveTo])
  @@map("payroll_policies")
}

model PayrollPolicyRule {
  id       String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  policyId String        @map("policy_id") @db.Uuid
  policy   PayrollPolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  label     String
  kind      PayrollRuleKind
  valueType PayrollRuleValueType
  value     Decimal              @db.Decimal(12, 4)
  isActive  Boolean              @default(true)
  sortOrder Int                  @default(0) @map("sort_order")

  // optional guardrails
  minAmount Decimal? @map("min_amount") @db.Decimal(12, 2)
  maxAmount Decimal? @map("max_amount") @db.Decimal(12, 2)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([policyId, kind, sortOrder])
  @@map("payroll_policy_rules")
}
